# ============================================
# Block-Hash Environment Configuration
# ============================================

# ── General ──────────────────────────────────
NODE_ENV=development
LOG_LEVEL=debug

# ── PostgreSQL ───────────────────────────────
DATABASE_URL=postgresql://blockhash:blockhash_secret@localhost:5432/blockhash
POSTGRES_USER=blockhash
POSTGRES_PASSWORD=blockhash_secret
POSTGRES_DB=blockhash

# ── ClickHouse ───────────────────────────────
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DB=blockhash_analytics

# ── Redis ────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# ── API Server ───────────────────────────────
API_PORT=3001
API_HOST=0.0.0.0
API_PREFIX=/api/v1
GRPC_PORT=50051
WS_PORT=3002

# ── Rate Limiting ────────────────────────────
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# ── JWT Auth ─────────────────────────────────
JWT_SECRET=change-this-to-a-secure-random-string
JWT_EXPIRATION=24h

# ── Blockchain RPC Endpoints ─────────────────
# Ethereum
ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
ETH_WS_URL=wss://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
ETH_RPC_URL_FALLBACK=https://mainnet.infura.io/v3/YOUR_KEY

# BNB Chain (BSC)
BNB_RPC_URL=https://bsc-dataseed1.binance.org
BNB_WS_URL=wss://bsc-ws-node.nariox.org
BNB_RPC_URL_FALLBACK=https://bsc-dataseed2.binance.org

# Bitcoin
BTC_RPC_URL=http://localhost:8332
BTC_RPC_USER=bitcoin
BTC_RPC_PASSWORD=bitcoin_secret

# Solana
SOL_RPC_URL=https://api.mainnet-beta.solana.com
SOL_WS_URL=wss://api.mainnet-beta.solana.com

# Arbitrum
ARB_RPC_URL=https://arb-mainnet.g.alchemy.com/v2/YOUR_KEY
ARB_WS_URL=wss://arb-mainnet.g.alchemy.com/v2/YOUR_KEY

# Base
BASE_RPC_URL=https://mainnet.base.org
BASE_WS_URL=wss://base-mainnet.g.alchemy.com/v2/YOUR_KEY

# Polygon
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY
POLYGON_WS_URL=wss://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY

# Avalanche
AVAX_RPC_URL=https://api.avax.network/ext/bc/C/rpc
AVAX_WS_URL=wss://api.avax.network/ext/bc/C/ws

# Tron
TRON_API_URL=https://api.trongrid.io
TRON_API_KEY=YOUR_TRON_API_KEY

# ── Whale Detection ─────────────────────────
WHALE_THRESHOLD_USD=1000000
WHALE_ALERT_COOLDOWN_MS=60000

# ── Smart Money ──────────────────────────────
SMART_MONEY_MIN_TRADES=50
SMART_MONEY_MIN_WINRATE=0.6
SMART_MONEY_LOOKBACK_DAYS=90

# ── Frontend ─────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:3002
